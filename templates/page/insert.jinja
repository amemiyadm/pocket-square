{% extends 'layout/base.jinja' %}
{% block js %}
    <script src="{{ static_file('js/insert.js') }}" type="module"></script>
{% endblock %}

{% block content %}
    <article>
        <div>
            <h1>記事追加</h1>
        </div>
        <hr>
        <form autocomplete="off" class="gap-4 grid" method="POST">
            <div class="gap-2 grid grid-cols-2">
                {% for field in form.admin_fields1() %}
                    {{ field.render() }}
                {% endfor %}
            </div>
            <div class="flex flex-wrap gap-2">
                {% for tag in all_tags if tag.is_category %}
                    <div class="gap-2 flex items-center">
                        <input id="tag-radio{{ loop.index }}" name="tags" type="radio" value="{{ tag.name }}">
                        <label for="tag-radio{{ loop.index }}">{{ tag.name }}</label>
                    </div>
                {% endfor %}
            </div>
            <div class="flex flex-wrap gap-2">
                {% for tag in all_tags if not tag.is_category %}
                    <div class="gap-2 flex items-center">
                        <input id="tag-check{{ loop.index }}" name="tags" type="checkbox" value="{{ tag.name }}">
                        <label for="tag-check{{ loop.index }}">{{ tag.name }}</label>
                    </div>
                {% endfor %}
            </div>
            {% for i in range(1, 7) %}
                <div class="gap-2 grid grid-cols-2">
                    <b class="col-span-2">ポケモン{{ i }}</b>
                    {% for field in form.admin_fields2(i) %}
                        {{ field.render() }}
                    {% endfor %}
                </div>
            {% endfor %}
            <button type="submit">追加</button>
        </form>
    </article>
{% endblock %}
